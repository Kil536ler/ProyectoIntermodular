[Unit]
Description=Tunel SSH Inverso Seguro
After=network.target

[Service]
User=root
Environment="AUTOSSH_GATETIME=0"
ExecStart=/usr/bin/autossh -M 0 -N -q -o "StrictHostKeyChecking no" -o "ServerAliveInterval 45" -o "ServerAliveCountMax 2" -i /root/.ssh/id_ed25519_tunel -R 2222:localhost:22 guardian_tunel@192.168.1.31
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
